<view class="page">
  <view wx:if="{{needLogin}}" class="gate">
    <text class="gate-t">登录后查看您联系过的会话</text>
    <button class="gate-btn" bindtap="goLogin">去登录</button>
  </view>

  <block wx:else>
    <view class="hint-top">与以下对象就某条信息有过站内留言。点整行进入会话，或点「查看信息」打开对应发布页。</view>
    <view wx:if="{{loading}}" class="hint">加载中…</view>
    <view wx:elif="{{empty}}" class="empty">暂无会话。在详情页点击「发站内留言」即可发起对话。</view>
    <view wx:else class="list">
      <view class="row" wx:for="{{threads}}" wx:key="_id">
        <view class="row-main" data-id="{{item._id}}" bindtap="openThread">
          <text class="title">{{item.listing_title_cache}}</text>
          <text class="preview">{{item.last_message_body || '（无内容）'}}</text>
          <text class="meta">对方尾号 {{item.other_openid_tail}} · {{item.listing_type === 'request' ? '宠主需求' : '寄养家庭'}}</text>
          <text wx:if="{{item.timeLabel}}" class="meta">最近 {{item.timeLabel}}</text>
        </view>
        <view class="row-side">
          <view wx:if="{{item.unread > 0}}" class="badge">{{item.unread > 99 ? '99+' : item.unread}}</view>
          <text
            class="link"
            wx:if="{{item.listing_id}}"
            catchtap="openListing"
            data-id="{{item.listing_id}}"
            data-type="{{item.listing_type}}"
          >查看信息</text>
        </view>
      </view>
    </view>
  </block>
</view>
