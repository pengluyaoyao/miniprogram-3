<view class="page">
  <view class="page-top">
    <view class="status-bar">
      <text class="time">9:41</text>
      <text class="signal">5G 87%</text>
    </view>

    <view class="header-row">
      <text class="title">寄养信息</text>
      <text class="hint">{{locationHint}}</text>
    </view>

    <view class="city-search">
    <input
      class="city-input"
      placeholder="搜索市区，如：浦东新区"
      value="{{cityInput}}"
      confirm-type="search"
      bindinput="onCityInput"
      bindconfirm="onCitySearch"
    />
    <button class="city-btn" size="mini" bindtap="onCitySearch">搜索</button>
    <text wx:if="{{activeCityQuery}}" class="city-clear" bindtap="onClearCity">全部</text>
    </view>
  </view>

  <view wx:if="{{loading}}" class="hint-loading">加载中…</view>
  <view wx:elif="{{empty}}" class="empty-box">
    <text wx:if="{{searchMode === 'city'}}">「{{activeCityQuery}}」暂无匹配。请换关键词或点「全部」查看列表。</text>
    <text wx:else>暂无已发布内容。可去「发布」提交信息。</text>
  </view>

  <block wx:else>
    <view class="page-above-scroll">
      <view class="type-switch">
        <view class="type-item {{feedType === 'provider' ? 'active' : ''}}" data-type="provider" bindtap="switchFeedType">
          寄养家庭
        </view>
        <view class="type-item {{feedType === 'request' ? 'active' : ''}}" data-type="request" bindtap="switchFeedType">
          宠主需求
        </view>
      </view>

      <text class="list-heading" wx:if="{{listCount > 0}}">共 {{listCount}} 条</text>
      <view wx:if="{{listCount === 0}}" class="empty-tab">
        <text wx:if="{{searchMode === 'city'}}">「{{activeCityQuery}}」暂无{{feedType === 'provider' ? '寄养家庭' : '宠主需求'}}。</text>
        <text wx:else>暂无{{feedType === 'provider' ? '寄养家庭' : '宠主需求'}}。</text>
      </view>
    </view>

    <scroll-view
      wx:if="{{listCount > 0}}"
      scroll-y
      class="waterfall-scroll"
      style="height: {{scrollViewHeight}}px;"
      enhanced
      show-scrollbar="{{false}}"
    >
      <view class="waterfall">
        <view class="waterfall-col">
          <view
            wx:for="{{leftColumn}}"
            wx:key="_id"
            class="note-card"
            data-id="{{item.id}}"
            data-type="{{item.listType}}"
            bindtap="goDetail"
          >
            <view class="cover-box">
              <view class="cover-ratio" style="height: {{item.coverHeightRpx}}rpx;"></view>
              <image
                wx:if="{{item.hasCover}}"
                class="cover-img"
                src="{{item.coverUrl}}"
                mode="aspectFill"
                lazy-load
                data-id="{{item.id}}"
                bindload="onCoverImageLoad"
              />
              <view
                wx:else
                class="cover-placeholder cover-placeholder-{{item.placeholderType}}"
              >
                <text class="cover-ph-icon">{{item.placeholderType === 'provider' ? '🏠' : '🐾'}}</text>
                <text class="cover-ph-text">{{item.placeholderType === 'provider' ? '环境待补充' : '宠物待补充'}}</text>
              </view>
            </view>
            <view class="note-body">
              <text class="note-title">{{item.name}}</text>
              <text class="note-city">{{item.locationCity}}</text>
              <view class="note-tags" wx:if="{{item.tags.length}}">
                <text class="note-tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="waterfall-col">
          <view
            wx:for="{{rightColumn}}"
            wx:key="_id"
            class="note-card"
            data-id="{{item.id}}"
            data-type="{{item.listType}}"
            bindtap="goDetail"
          >
            <view class="cover-box">
              <view class="cover-ratio" style="height: {{item.coverHeightRpx}}rpx;"></view>
              <image
                wx:if="{{item.hasCover}}"
                class="cover-img"
                src="{{item.coverUrl}}"
                mode="aspectFill"
                lazy-load
                data-id="{{item.id}}"
                bindload="onCoverImageLoad"
              />
              <view
                wx:else
                class="cover-placeholder cover-placeholder-{{item.placeholderType}}"
              >
                <text class="cover-ph-icon">{{item.placeholderType === 'provider' ? '🏠' : '🐾'}}</text>
                <text class="cover-ph-text">{{item.placeholderType === 'provider' ? '环境待补充' : '宠物待补充'}}</text>
              </view>
            </view>
            <view class="note-body">
              <text class="note-title">{{item.name}}</text>
              <text class="note-city">{{item.locationCity}}</text>
              <view class="note-tags" wx:if="{{item.tags.length}}">
                <text class="note-tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </block>

  <view class="tabbar">
    <view class="tab-item active" bindtap="goHome">首页</view>
    <view class="tab-item" bindtap="goPublish">发布</view>
    <view class="tab-item tab-with-badge" bindtap="goMy">
      <text>我的</text>
      <view class="tab-badge" wx:if="{{msgUnread > 0}}">{{msgUnread > 99 ? '99+' : msgUnread}}</view>
    </view>
  </view>
</view>
