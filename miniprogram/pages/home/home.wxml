<view class="page">
  <view class="status-bar">
    <text class="time">9:41</text>
    <text class="signal">5G 87%</text>
  </view>

  <view class="header">
    <text class="title">附近信息</text>
    <text class="sub">寄养家庭 · 宠主需求</text>
  </view>

  <view wx:if="{{loading}}" class="hint-loading">加载中…</view>
  <view wx:elif="{{empty}}" class="empty-box">
    <text>暂无已发布内容。去「发布」分别以寄养家庭或宠物主身份提交即可出现在首页与地图。</text>
  </view>

  <block wx:else>
    <view wx:if="{{providers.length > 0}}" class="section">
      <text class="section-title">寄养家庭</text>
      <view class="list">
        <view class="card" wx:for="{{providers}}" wx:key="_id">
          <view class="card-body">
            <view class="card-top">
              <text class="name">{{item.name}}</text>
              <text class="distance">{{item.distance}}</text>
            </view>
            <view class="photo-grid">
              <view class="photo" wx:for="{{item.photos}}" wx:for-item="photo" wx:key="*this">{{photo}}</view>
            </view>
            <view class="tags">
              <text class="tag" wx:for="{{item.tags}}" wx:key="*this">{{item}}</text>
            </view>
            <text class="desc">{{item.desc}}</text>
          </view>
          <button
            class="primary-btn"
            data-id="{{item.id}}"
            data-type="{{item.listType}}"
            bindtap="goDetail"
          >查看详情 / 联系TA</button>
        </view>
      </view>
    </view>

    <view wx:if="{{requests.length > 0}}" class="section">
      <text class="section-title">宠主需求</text>
      <view class="list">
        <view class="card" wx:for="{{requests}}" wx:key="_id">
          <view class="card-body">
            <view class="card-top">
              <text class="name">{{item.name}}</text>
              <text class="distance">{{item.distance}}</text>
            </view>
            <view class="photo-grid">
              <view class="photo" wx:for="{{item.photos}}" wx:for-item="photo" wx:key="*this">{{photo}}</view>
            </view>
            <view class="tags">
              <text class="tag" wx:for="{{item.tags}}" wx:key="*this">{{item}}</text>
            </view>
            <text class="desc">{{item.desc}}</text>
          </view>
          <button
            class="primary-btn"
            data-id="{{item.id}}"
            data-type="{{item.listType}}"
            bindtap="goDetail"
          >查看详情 / 联系TA</button>
        </view>
      </view>
    </view>
  </block>

  <view class="tabbar">
    <view class="tab-item active" bindtap="goHome">首页</view>
    <view class="tab-item" bindtap="goPublish">发布</view>
    <view class="tab-item" bindtap="goMap">地图</view>
    <view class="tab-item tab-with-badge" bindtap="goMy">
      <text>我的</text>
      <view class="tab-badge" wx:if="{{msgUnread > 0}}">{{msgUnread > 99 ? '99+' : msgUnread}}</view>
    </view>
  </view>
</view>
