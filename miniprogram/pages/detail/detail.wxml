<navigation-bar title="{{pageTitle}}" back="{{true}}" color="#0f172a" background="#f8fafc"></navigation-bar>

<view class="page">
  <view wx:if="{{loading}}" class="hint-state">加载中…</view>
  <view wx:elif="{{loadError}}" class="hint-state hint-error">{{loadError}}</view>

  <block wx:else>
    <view class="card">
      <text class="name">{{heroName}}</text>
      <text class="sub">{{heroSub}}</text>
      <view class="tags" wx:if="{{tagList.length}}">
        <text class="tag" wx:for="{{tagList}}" wx:key="*this">{{item}}</text>
      </view>
    </view>

    <view class="card" wx:if="{{showInfoSection}}">
      <text class="section-title">发布信息</text>
      <view class="info-list">
        <view class="info-row" wx:for="{{infoRows}}" wx:key="label">
          <text class="info-label">{{item.label}}</text>
          <text class="info-value">{{item.value}}</text>
        </view>
      </view>
    </view>

    <view class="card xhs-card" wx:if="{{showXhsSection}}">
      <text class="xhs-title" wx:if="{{xhsTitle}}">{{xhsTitle}}</text>
      <text class="xhs-body" wx:if="{{xhsBody}}" selectable>{{xhsBody}}</text>
      <view class="xhs-highlights" wx:if="{{xhsHighlights.length}}">
        <view class="xhs-highlight-item" wx:for="{{xhsHighlights}}" wx:key="*this">{{item}}</view>
      </view>
      <view class="xhs-tag-row" wx:if="{{xhsHashtags.length}}">
        <text class="xhs-tag-chip" wx:for="{{xhsHashtags}}" wx:key="*this">{{item}}</text>
      </view>
      <button class="xhs-copy-btn" bindtap="copyXhs">复制文案</button>
    </view>

    <view class="card" wx:if="{{photoCells.length}}">
      <text class="section-title">{{photoSectionTitle}}</text>
      <text class="photo-tip">点击图片可放大查看</text>
      <view class="photo-grid">
        <image
          wx:for="{{photoCells}}"
          wx:key="idx"
          wx:if="{{item.url}}"
          class="photo photo-img"
          src="{{item.url}}"
          mode="aspectFill"
          data-idx="{{item.idx}}"
          bindtap="onPreviewPhoto"
        />
      </view>
    </view>

    <view class="card" wx:if="{{descSectionTitle && descText}}">
      <text class="section-title">{{descSectionTitle}}</text>
      <text class="desc-body">{{descText}}</text>
    </view>
  </block>

  <view class="risk">
    平台仅提供信息对接，不参与交易、担保或履约。联系前请核验身份与责任边界。
  </view>

  <view class="bottom-bar" wx:if="{{!loading && !loadError}}">
    <button class="share-btn" open-type="share">分享好友</button>
    <button class="share-btn share-timeline-btn" bindtap="onShareTimelineGuide">朋友圈</button>
    <button class="report-btn" bindtap="goReport">举报</button>
    <button class="secondary-btn" bindtap="onFavorite">收藏</button>
    <button class="primary-btn" bindtap="goContact">留言</button>
  </view>

  <view class="tabbar">
    <view class="tab-item" bindtap="goHome">首页</view>
    <view class="tab-item" bindtap="goPublish">发布</view>
    <view class="tab-item tab-with-badge" bindtap="goMy">
      <text>我的</text>
      <view class="tab-badge" wx:if="{{msgUnread > 0}}">{{msgUnread > 99 ? '99+' : msgUnread}}</view>
    </view>
  </view>
</view>
