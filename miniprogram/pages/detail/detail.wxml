<view class="page">
  <view class="status-bar">
    <text class="time">9:41</text>
    <text class="signal">5G 87%</text>
  </view>

  <view class="title">{{pageTitle}}</view>

  <view wx:if="{{loading}}" class="hint-state">加载中…</view>
  <view wx:elif="{{loadError}}" class="hint-state hint-error">{{loadError}}</view>

  <block wx:else>
    <view class="card">
      <text class="name">{{heroName}}</text>
      <text class="sub">{{heroSub}}</text>
      <view class="tags">
        <text class="tag" wx:for="{{tagList}}" wx:key="*this">{{item}}</text>
      </view>
    </view>

    <view class="card">
      <text class="section-title">{{photoSectionTitle}}</text>
      <view class="photo-grid">
        <block wx:for="{{photoCells}}" wx:key="idx">
          <image wx:if="{{item.url}}" class="photo photo-img" src="{{item.url}}" mode="aspectFill" />
          <view wx:else class="photo">{{item.label}}</view>
        </block>
      </view>
    </view>

    <view class="card">
      <text class="section-title">{{descSectionTitle}}</text>
      <text class="desc-body">{{descText}}</text>
    </view>
  </block>

  <view class="risk">
    平台仅提供信息对接，不参与交易、担保或履约。联系前请核验身份与责任边界。
  </view>

  <view class="bottom-bar" wx:if="{{!loading && !loadError}}">
    <button class="report-btn" bindtap="goReport">举报</button>
    <button class="secondary-btn" bindtap="onFavorite">收藏</button>
    <button class="primary-btn" bindtap="goContact">发站内留言</button>
  </view>

  <view class="tabbar">
    <view class="tab-item" bindtap="goHome">首页</view>
    <view class="tab-item" bindtap="goPublish">发布</view>
    <view class="tab-item" bindtap="goMap">地图</view>
    <view class="tab-item tab-with-badge" bindtap="goMy">
      <text>我的</text>
      <view class="tab-badge" wx:if="{{msgUnread > 0}}">{{msgUnread > 99 ? '99+' : msgUnread}}</view>
    </view>
  </view>
</view>
