<view class="page">
  <view class="status-bar">
    <text class="time">9:41</text>
    <text class="signal">5G 87%</text>
  </view>

  <view wx:if="{{alreadyLoggedIn}}" class="card">
    <text class="title">当前已登录</text>
    <text class="desc">可返回继续操作，或退出登录后重新登录 / 调试地理位置等授权流程。</text>
    <button class="primary-btn" bindtap="onContinueLoggedIn">返回上一页</button>
    <button class="logout-btn" bindtap="onLogoutFromLogin">退出登录</button>
  </view>

  <view wx:else class="card">
    <text class="title">登录后继续</text>
    <text class="desc">将使用微信头像、昵称等信息写入云数据库 users；手机号等可在资料页补充。</text>
    <button class="primary-btn" bindtap="onLoginTap">微信授权登录（头像昵称）</button>
    <button class="ghost-btn" bindtap="onLoginMinimalTap">仅同步 OpenID（模拟器/调试）</button>
    <button class="ghost-btn" bindtap="onSkipTap">暂不登录</button>
  </view>
</view>
