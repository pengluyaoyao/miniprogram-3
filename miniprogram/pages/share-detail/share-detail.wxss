/* 分享详情页面样式 */
.share-detail-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f4ff 0%, #ffffff 50%);
  padding: 32rpx;
  padding-bottom: 120rpx;
}

/* 顶部标识 */
.share-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background-color: rgba(0, 82, 217, 0.1);
  border-radius: 24rpx;
  margin-bottom: 32rpx;
}

.badge-text {
  font-size: 24rpx;
  color: #0052d9;
  font-weight: 500;
}

/* 标题区域 */
.title-section {
  margin-bottom: 32rpx;
}

.share-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #000000;
  line-height: 1.4;
  display: block;
}

/* 信息卡片 */
.info-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #000000;
}

.title-icon {
  font-size: 32rpx;
}

/* 户型信息网格 */
.info-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
}

.info-label {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #000000;
}

/* 亮点列表 */
.highlights-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.highlight-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background: linear-gradient(90deg, rgba(0, 82, 217, 0.05) 0%, rgba(0, 82, 217, 0) 100%);
  border-left: 4rpx solid #0052d9;
  border-radius: 8rpx;
}

.highlight-dot {
  font-size: 32rpx;
  color: #0052d9;
  line-height: 1;
}

.highlight-text {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

/* 分析内容 */
.analysis-content {
  padding: 24rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  line-height: 1.8;
}

.analysis-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
  white-space: pre-wrap;
  word-wrap: break-word;
}

/* 引导卡片 */
.cta-card {
  background: linear-gradient(135deg, #0052d9 0%, #266fe8 100%);
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 82, 217, 0.3);
  margin-top: 48rpx;
}

.cta-icon {
  font-size: 64rpx;
  margin-bottom: 24rpx;
}

.cta-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.cta-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 32rpx;
  line-height: 1.5;
}

.cta-button {
  background-color: #ffffff !important;
  color: #0052d9 !important;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

/* 底部说明 */
.footer-tips {
  text-align: center;
  padding: 48rpx 0 32rpx 0;
}

.tip-text {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.6;
}

/* 动画效果 */
.info-card {
  animation: slideUp 0.4s ease;
}

.cta-card {
  animation: slideUp 0.6s ease;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

