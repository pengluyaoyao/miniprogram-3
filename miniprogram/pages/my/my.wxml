<view class="page">
  <view class="status-bar">
    <text class="time">9:41</text>
    <text class="signal">5G 87%</text>
  </view>

  <view class="title">我的</view>

  <view wx:if="{{!loggedIn}}" class="login-gate">
    <text class="gate-title">登录后使用完整功能</text>
    <text class="gate-desc">发布、收藏、站内留言等需先登录。</text>
    <button class="gate-btn" bindtap="goLogin">去登录</button>
    <view class="menu-list gate-menu">
      <view class="menu-item" bindtap="goContactUs">联系我们</view>
    </view>
  </view>

  <block wx:else>
    <view class="profile-card">
      <text class="name">{{userNickname}}</text>
      <text class="role" wx:if="{{userOpenidSuffix}}">ID 尾号 {{userOpenidSuffix}} · 默认角色：宠物主人</text>
      <text class="role" wx:else>当前角色：宠物主人</text>
    </view>

    <view class="inbox-entry" bindtap="goInbox">
      <text class="inbox-title">新消息</text>
      <text class="inbox-sub">站内留言与历史对话</text>
      <view class="inbox-badge" wx:if="{{msgUnread > 0}}">{{msgUnread > 99 ? '99+' : msgUnread}}</view>
      <text class="inbox-arrow">›</text>
    </view>

    <view class="menu-list">
      <view class="menu-item" bindtap="goMyPets">我的宠物档案</view>
      <view class="menu-item" bindtap="goMyPublications">我的发布</view>
      <view class="menu-item" bindtap="goMyFavorites">我的收藏</view>
      <view class="menu-item" bindtap="goMyContacts">联系过的对象</view>
      <view class="menu-item" bindtap="goMyReports">举报记录</view>
      <view class="menu-item" bindtap="goContactUs">联系我们</view>
      <view class="menu-item" bindtap="goSettings">设置</view>
    </view>

    <button class="logout-btn" bindtap="onLogoutTap">退出登录</button>
  </block>

  <view class="tabbar">
    <view class="tab-item" bindtap="goHome">首页</view>
    <view class="tab-item" bindtap="goPublish">发布</view>
    <view class="tab-item tab-with-badge active" bindtap="goMy">
      <text>我的</text>
      <view class="tab-badge" wx:if="{{msgUnread > 0}}">{{msgUnread > 99 ? '99+' : msgUnread}}</view>
    </view>
  </view>
</view>
