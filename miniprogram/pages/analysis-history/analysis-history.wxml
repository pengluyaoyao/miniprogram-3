<!--分析记录页面-->
<view class="history-container">
  <!-- 加载状态 -->
  <view class="loading-wrapper" wx:if="{{loading}}">
    <t-loading theme="spinner" size="48rpx" text="加载中..." />
  </view>

  <!-- 空状态 -->
  <view class="empty-wrapper" wx:if="{{!loading && isEmpty}}">
    <t-empty 
      icon="chart" 
      description="暂无分析记录"
    />
  </view>

  <!-- 记录列表 -->
  <view class="records-list" wx:if="{{!loading && !isEmpty}}">
    <view 
      class="record-item" 
      wx:for="{{records}}" 
      wx:key="_id"
      bindtap="onRecordTap"
      data-id="{{item._id}}"
    >
      <!-- 户型图 -->
      <view class="record-image">
        <t-image 
          src="{{item.houseDescription || item.imageUrl}}" 
          mode="aspectFill"
          width="200rpx"
          height="200rpx"
          shape="round"
          error="加载失败"
        />
      </view>

      <!-- 记录信息 -->
      <view class="record-info">
        <!-- 户型信息 -->
        <view class="house-info">
          <text class="info-label">户型：</text>
          <text class="info-value">{{item.houseInfo.rooms || '未填写'}}</text>
          <text class="info-divider">|</text>
          <text class="info-label">面积：</text>
          <text class="info-value">{{item.houseInfo.area || '未填写'}}</text>
        </view>

        <!-- 分析结果摘要 -->
        <view class="analysis-summary">
          <text class="summary-text">{{item.analysisResult.summary}}</text>
        </view>

        <!-- 评分 -->
        <view class="score-section" wx:if="{{item.analysisResult.overallScore}}">
          <text class="score-label">综合评分：</text>
          <text class="score-value">{{item.analysisResult.overallScore}}分</text>
        </view>

        <!-- 时间 -->
        <view class="time-section">
          <t-icon name="time" size="28rpx" color="#999" />
          <text class="time-text">{{item.createTime}}</text>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="record-actions">
        <view 
          class="action-btn delete-btn" 
          catchtap="onDeleteRecord"
          data-id="{{item._id}}"
        >
          <t-icon name="delete" size="36rpx" color="#e34d59" />
        </view>
      </view>
    </view>
  </view>

  <!-- 浮动详情窗口 -->
  <view class="detail-modal" wx:if="{{showDetailModal}}" catchtap="closeDetailModal">
    <view class="modal-content" catchtap="{{null}}">
      <!-- 关闭按钮 -->
      <view class="modal-close" bindtap="closeDetailModal">
        <t-icon name="close" size="40rpx" color="#666" />
      </view>

      <!-- 标题 -->
      <view class="modal-title">分析结果</view>

      <!-- 可滚动的内容区域 -->
      <scroll-view class="modal-scroll" scroll-y>
        <view class="modal-body">
          <!-- 综合评分 -->
          <view class="modal-score" wx:if="{{currentRecord.analysisResult.overallScore}}">
            <view class="score-label">综合评分</view>
            <view class="score-value">{{currentRecord.analysisResult.overallScore}}</view>
            <view class="score-unit">分</view>
          </view>

          <!-- 分析总结 -->
          <view class="modal-section" wx:if="{{currentRecord.analysisResult.summary}}">
            <view class="section-title">分析总结</view>
            <view class="section-content">
              <text class="content-text">{{currentRecord.analysisResult.summary}}</text>
            </view>
          </view>

          <!-- 各方面分析 -->
          <view class="modal-section" wx:if="{{currentRecord.analysisResult.aspects && currentRecord.analysisResult.aspects.length > 0}}">
            <view class="section-title">详细分析</view>
            <view 
              class="aspect-item" 
              wx:for="{{currentRecord.analysisResult.aspects}}" 
              wx:key="type"
            >
              <view class="aspect-header">
                <view class="aspect-title">{{item.title}}</view>
                <view class="aspect-score" wx:if="{{item.score}}">{{item.score}}分</view>
              </view>
              <view class="aspect-content">
                <text class="content-text">{{item.content}}</text>
              </view>
              <!-- 改善建议 -->
              <view class="aspect-suggestions" wx:if="{{item.suggestions && item.suggestions.length > 0}}">
                <view class="suggestions-title">改善建议：</view>
                <view class="suggestion-item" wx:for="{{item.suggestions}}" wx:for-item="suggestion" wx:key="*this">
                  • {{suggestion}}
                </view>
              </view>
            </view>
          </view>

          <!-- 户型信息 -->
          <view class="modal-section">
            <view class="section-title">户型信息</view>
            <view class="info-row">
              <text class="info-label">房间数：</text>
              <text class="info-value">{{currentRecord.houseInfo.rooms || '未填写'}}</text>
            </view>
            <view class="info-row">
              <text class="info-label">面积：</text>
              <text class="info-value">{{currentRecord.houseInfo.area || '未填写'}}</text>
            </view>
            <view class="info-row">
              <text class="info-label">朝向：</text>
              <text class="info-value">{{currentRecord.houseInfo.orientation || '未填写'}}</text>
            </view>
            <view class="info-row">
              <text class="info-label">楼层：</text>
              <text class="info-value">{{currentRecord.houseInfo.floor || '未填写'}}/{{currentRecord.houseInfo.totalFloors || '未填写'}}</text>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>

