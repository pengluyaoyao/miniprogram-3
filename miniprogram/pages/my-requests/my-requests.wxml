<view class="page">
  <view class="page-head">
    <text class="page-title">我的发布</text>
    <text class="page-sub">您发布过的宠主需求与寄养家庭信息</text>
  </view>

  <view wx:if="{{needLogin}}" class="gate">
    <text class="gate-t">登录后查看我的发布</text>
    <button class="gate-btn" bindtap="goLogin">去登录</button>
  </view>

  <block wx:else>
    <view wx:if="{{loading}}" class="hint">加载中…</view>
    <view wx:elif="{{empty}}" class="empty">您还没有发布过信息。请到「发布」选择身份填写并提交。</view>
    <view wx:else class="list">
      <view class="row" wx:for="{{rows}}" wx:key="_id">
        <view
          class="row-main"
          data-id="{{item._id}}"
          data-type="{{item.listType}}"
          bindtap="openDetail"
        >
          <view class="row-head">
            <text class="type-tag">{{item.typeLabel}}</text>
            <text class="status-tag">{{item.statusLabel}}</text>
          </view>
          <text class="title">{{item.title}}</text>
          <text class="preview">{{item.sub}}</text>
          <text wx:if="{{item.timeLabel}}" class="meta">提交时间 {{item.timeLabel}}</text>
        </view>
        <view class="row-actions" wx:if="{{item.canEdit}}">
          <button
            class="act-btn act-edit"
            size="mini"
            data-id="{{item._id}}"
            data-type="{{item.listType}}"
            catchtap="onEdit"
          >
            修改
          </button>
          <button
            class="act-btn act-del"
            size="mini"
            data-id="{{item._id}}"
            data-type="{{item.listType}}"
            catchtap="onDelete"
          >
            删除
          </button>
        </view>
        <view class="row-actions" wx:else>
          <text class="act-muted">已下架</text>
        </view>
      </view>
    </view>
  </block>
</view>
